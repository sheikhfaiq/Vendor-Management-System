PORT=5050
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/vms_db?schema=public"

JWT_SECRET=super_secret_jwt_key_for_vms_123
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_for_vms_456
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Storage Configuration (Local vs S3)
USE_S3=false
BACKEND_URL=http://localhost:5050
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_bucket_name

